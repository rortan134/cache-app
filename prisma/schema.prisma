datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./client"
}

enum LibraryItemSource {
  cache_note
  chrome_bookmarks
  github_starred_repositories
  google_photos
  instagram
  other
  pinterest
  tiktok
  x_bookmarks
  youtube_watch_later
}

enum LibraryItemKind {
  bookmark
  folder
  note
}

enum CollectionPriority {
  none
  very_relevant
  relevant
  peripheral
  archive
}

enum LibraryActivityEventKind {
  collection_created
  collection_shared
  item_added
  item_collected
  item_updated
  source_connected
}

/// Managed by better-auth core. Do not rename fields.
model User {
  id                       String                 @id
  name                     String
  email                    String                 @unique
  emailVerified            Boolean                @default(false)
  image                    String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  smartCollectionsDisabled Boolean                @default(false)
  stripeCustomerId         String?
  extensionIngestToken     String?                @unique
  sessions                 Session[]
  accounts                 Account[]
  libraryItems             LibraryItem[]
  collections              Collection[]
  libraryActivityEvents    LibraryActivityEvent[]

  feedbackEntries Feedback[]

  @@index([stripeCustomerId])
  @@map("user")
}

/// Application-owned. Named groupings of library items.
model Collection {
  id             String                 @id @default(cuid())
  userId         String
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  nameKey        String
  description    String?
  priority       CollectionPriority     @default(none)
  shareId        String?                @unique
  sharedAt       DateTime?
  items          LibraryItem[]
  activityEvents LibraryActivityEvent[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([userId, nameKey])
  @@index([userId])
  @@map("collection")
}

/// Application-owned. Append-only activity events for the user's library timeline.
model LibraryActivityEvent {
  id            String                   @id @default(cuid())
  userId        String
  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind          LibraryActivityEventKind
  libraryItemId String?
  libraryItem   LibraryItem?             @relation(fields: [libraryItemId], references: [id], onDelete: SetNull)
  collectionId  String?
  collection    Collection?              @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  metadata      Json?
  occurredAt    DateTime                 @default(now())
  createdAt     DateTime                 @default(now())

  @@index([userId, occurredAt])
  @@index([libraryItemId])
  @@index([collectionId])
  @@map("library_activity_event")
}

/// Application-owned. User's saved content items.
model LibraryItem {
  id               String                 @id @default(cuid())
  userId           String
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  source           LibraryItemSource
  kind             LibraryItemKind        @default(bookmark)
  externalId       String
  sourceAliasIds   String[]               @default([])
  browserProfileId String                 @default("default")
  parentExternalId String?
  sourceDeviceId   String?
  sourceDeviceName String?
  url              String
  caption          String? // Non-note item caption/label. Notes use noteContentHtml/text only.
  noteContentHtml  String?
  noteContentState Json?
  noteContentText  String?
  sourceMetadata   Json?
  postedAt         DateTime?
  scrapedAt        DateTime?
  collections      Collection[]
  activityEvents   LibraryActivityEvent[]
  reviewedAt       DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([userId, source, browserProfileId, externalId])
  @@index([userId])
  @@index([userId, source, browserProfileId])
  @@index([userId, source, browserProfileId, parentExternalId], map: "library_item_user_source_profile_parent_idx")
  @@index([userId, reviewedAt])
  @@map("library_item")
}

/// Managed by better-auth core. Do not rename fields.
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

/// Managed by better-auth core. Do not rename fields.
model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId, providerId])
  @@index([providerId, accountId])
  @@map("account")
}

/// Managed by better-auth core. Do not rename fields.
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

/// Managed by @better-auth/stripe plugin. Do not rename fields.
model Subscription {
  id                   String    @id
  plan                 String
  referenceId          String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               String?   @default("incomplete")
  periodStart          DateTime?
  periodEnd            DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean?  @default(false)
  cancelAt             DateTime?
  canceledAt           DateTime?
  endedAt              DateTime?
  seats                Int?
  billingInterval      String?
  stripeScheduleId     String?

  @@index([referenceId])
  @@map("subscription")
}

/// Application-owned. User feedback submissions.
model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  pagePath  String
  message   String
  createdAt DateTime @default(now())

  @@index([pagePath])
  @@index([userId])
  @@map("feedback")
}
