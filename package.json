    "scripts": {
        "clean": "find . -name node_modules -o -name .next -o -name .swc -o -name tsconfig.buildinfo -type d -prune | xargs rm -rf",
        "dev": "NEXT_TELEMETRY_DISABLED=1 bun run --bun next dev",
        "build": "NEXT_TELEMETRY_DISABLED=1 bunx gt translate && NEXT_TELEMETRY_DISABLED=1 bun run --bun next build",
        "start": "NEXT_TELEMETRY_DISABLED=1 bun run --bun next start",
        "db-deploy": "prisma migrate deploy",
        "postinstall": "prisma generate",
        "db-migrate": "prisma migrate dev",
        "lint": "ultracite check",
        "lint:fix": "ultracite fix",
        "test": "bun test",
        "analyze": "next experimental-analyze",
        "type-check": "tsc --noEmit --emitDeclarationOnly false",
        "validate": "knip --cache --strict",
        "prepare": "husky"
    },
