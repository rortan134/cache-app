{
    "$schema": "./node_modules/knip/schema.json",
    "entry": [
        "prisma.config.ts",
        "load-translations.ts",
        "extensions/cache-app/cache-config.js",
        "extensions/cache-app/cache-extension-runtime.js",
        "extensions/cache-app/cache-site-bootstrap.js",
        "extensions/cache-app/cache-site-page-bridge.js",
        "extensions/cache-app/content.js",
        "extensions/cache-app/popup.css",
        "extensions/cache-app/popup.js",
        "extensions/cache-app/service-worker.js",
        "extensions/cache-app/youtube-page-bootstrap.js"
    ],
    "ignoreIssues": {
        "prisma/client/**": [
            "files",
            "exports",
            "types",
            "nsExports",
            "nsTypes"
        ],
        "prisma/schema.prisma": ["files"]
    },
    "rules": {
        "exports": "off",
        "nsExports": "off",
        "types": "off"
    }
}
