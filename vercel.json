{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "bunVersion": "1.x",
    "crons": [
        {
            "path": "/api/cron/automations",
            "schedule": "0 0 * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/docs",
            "destination": "https://cache.mintlify.dev/docs"
        },
        {
            "source": "/docs/:match*",
            "destination": "https://cache.mintlify.dev/docs/:match*"
        }
    ]
}
