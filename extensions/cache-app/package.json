{
    "name": "cache-app-extension",
    "displayName": "Save to Cache App",
    "version": "1.0.0",
    "description": "Save pages into your Cache. Sync Instagram Saved, TikTok Favorites, YouTube Watch Later, and Chrome bookmarks.",
    "homepage": "https://cachd.app",
    "private": true,
    "scripts": {
        "dev": "plasmo dev",
        "build": "plasmo build",
        "package": "plasmo build && plasmo package"
    },
    "dependencies": {
        "plasmo": "0.90.5",
        "react": "19.2.7",
        "react-dom": "19.2.7"
    },
    "devDependencies": {
        "@types/chrome": "0.2.2",
        "@types/node": "25.9.3",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "typescript": "7.0.2"
    },
    "manifest": {
        "homepage_url": "https://cachd.app",
        "minimum_chrome_version": "116",
        "action": {
            "default_title": "Save to Cache"
        },
        "host_permissions": [
            "https://www.instagram.com/*",
            "https://www.tiktok.com/*",
            "https://www.youtube.com/*",
            "https://cachd.app/*",
            "https://*.cachd.app/*"
        ],
        "permissions": [
            "bookmarks",
            "scripting",
            "storage",
            "tabs"
        ]
    }
}
