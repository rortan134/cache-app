# i18n
GT_API_KEY=
GT_PROJECT_ID=

# Database
DATABASE_URL=
REDIS_URL=

# Auth (generate secret: bunx @better-auth/cli@latest secret)
BETTER_AUTH_SECRET=
# Canonical app URL for OAuth redirects
BETTER_AUTH_URL=http://localhost:3000

NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional comma-separated extra origins for cookies/OAuth (e.g. preview deployments)
# TRUSTED_ORIGINS=
# Rate limiting
ARCJET_KEY=

# Google OAuth (sign-in / sign-up)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI in Google Cloud Console: {BETTER_AUTH_URL or NEXT_PUBLIC_APP_URL}/api/auth/callback/google
# Google Photos Picker: enable the Google Photos Picker API and add
# https://www.googleapis.com/auth/photospicker.mediaitems.readonly to OAuth consent scopes.

# LLMs
# Google AI Studio API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Redirect URI in GitHub OAuth App: {BETTER_AUTH_URL or NEXT_PUBLIC_APP_URL}/api/auth/callback/github

# X (Twitter) OAuth
X_CLIENT_ID=
X_CLIENT_SECRET=
# Redirect URI in X Developer Portal: {BETTER_AUTH_URL or NEXT_PUBLIC_APP_URL}/api/auth/callback/x

# Pinterest OAuth (tokens live on Account rows for Display API)
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
# Redirect URI in Pinterest: {BETTER_AUTH_URL or NEXT_PUBLIC_APP_URL}/api/auth/callback/pinterest

# Extension ingest (optional): if set, Bearer matching this token maps to EXTENSION_FALLBACK_USER_ID (dev/CI)
# INSTAGRAM_SAVED_INGEST_TOKEN=
# EXTENSION_FALLBACK_USER_ID=

# Stripe
STRIPE_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=

# Workflow (durable execution)
WORKFLOW_TARGET_WORLD="@workflow/world-postgres"
# Postgres URL for workflow storage. Falls back to DATABASE_URL if unset.
# WORKFLOW_POSTGRES_URL=

# Cron secret used to authenticate scheduled job triggers (e.g., from cron-job.org or K8s CronJob)
# Required in production. Generate: openssl rand -hex 32
CRON_SECRET=
