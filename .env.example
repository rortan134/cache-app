# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Canonical URL for OAuth redirects
BETTER_AUTH_URL=http://localhost:3000
# Optional comma-separated extra origins for cookies/OAuth (e.g. preview deployments)
# TRUSTED_ORIGINS=

# Auth
# Generate: bunx @better-auth/cli@latest secret
BETTER_AUTH_SECRET=
# Rate limiting & bot protection
ARCJET_KEY=

# Database
DATABASE_URL=
REDIS_URL=

# OAuth — Google
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI: {BETTER_AUTH_URL or NEXT_PUBLIC_APP_URL}/api/auth/callback/google
# Google Photos Picker: enable the Google Photos Picker API and add
# https://www.googleapis.com/auth/photospicker.mediaitems.readonly to OAuth consent scopes.

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Redirect URI: {BETTER_AUTH_URL or NEXT_PUBLIC_APP_URL}/api/auth/callback/github

# OAuth — X
X_CLIENT_ID=
X_CLIENT_SECRET=
# Redirect URI: {BETTER_AUTH_URL or NEXT_PUBLIC_APP_URL}/api/auth/callback/x

# OAuth — Pinterest
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
# Redirect URI: {BETTER_AUTH_URL or NEXT_PUBLIC_APP_URL}/api/auth/callback/pinterest

# OAuth — Notion
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# Create a public integration at https://www.notion.so/my-integrations
# Redirect URI: {BETTER_AUTH_URL}/api/auth/oauth2/callback/notion
# Capabilities: insert content (and read user info for /users/me)

# i18n
GT_API_KEY=
GT_PROJECT_ID=

# AI
AI_GATEWAY_API_KEY=
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Search API
TAVILY_API_KEY=

# Email (SMTP)
RESEND_API_KEY=
NEXT_PUBLIC_EMAIL_FROM=
EMAIL_FROM=
EMAIL_SERVER_HOST=
EMAIL_SERVER_PASSWORD=
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=

# Cron
# Required in production. Generate: openssl rand -hex 32
CRON_SECRET=

# Workflow (durable execution)
# WORKFLOW_TARGET_WORLD="@workflow/world-postgres"
# Falls back to DATABASE_URL if unset
# WORKFLOW_POSTGRES_URL=

# Extension Ingest
# If set, Bearer matching this token maps to EXTENSION_FALLBACK_USER_ID (dev/CI)
# INSTAGRAM_SAVED_INGEST_TOKEN=
# EXTENSION_FALLBACK_USER_ID=
